POSTGRES_PASSWORD=supersecret
DATABASE_URL=postgresql+asyncpg://taskcash:supersecret@postgres:5432/taskcash
REDIS_URL=redis://redis:6379/0

# Пользовательский бот (клиентский): мини-апп, проверки подписки, уведомления
BOT_TOKEN=your_user_bot_token
BOT_USERNAME=TaskCashAppBot

MINI_APP_URL=https://user.taskcashbot.ru

# Админский бот: панель управления и рассылка
ADMIN_BOT_TOKEN=your_admin_bot_token
ADMIN_APP_URL=https://admin.taskcashbot.ru

# Telegram ID администраторов через запятую (пусто = все имеют доступ)
ADMIN_TG_IDS=

BACKEND_URL=http://backend:8000

JWT_SECRET=change_this_to_random_secret_64_chars
JWT_EXPIRE_HOURS=168

ADMIN_SECRET=change_this_admin_secret

MIN_WITHDRAWAL=10.0
MAX_WITHDRAWAL_DAY=1000.0
WITHDRAWAL_FEE_PERCENT=5.0

REFERRAL_REWARD=0.50
REFERRAL_MIN_TASKS=3
