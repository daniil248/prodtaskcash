POSTGRES_PASSWORD=supersecret
DATABASE_URL=postgresql+asyncpg://taskcash:supersecret@postgres:5432/taskcash
REDIS_URL=redis://redis:6379/0

# Пользовательский бот (для верификации подписок + уведомлений пользователей)
BOT_TOKEN=your_user_bot_token_here
BOT_USERNAME=TaskCashBot
USER_BOT_TOKEN=your_user_bot_token_here

# Ссылка на мини-апку (https://ваш_домен или ngrok URL для разработки)
MINI_APP_URL=https://your-domain.com

# Админский бот
ADMIN_BOT_TOKEN=your_admin_bot_token_here
ADMIN_APP_URL=https://your-domain.com/admin

# Telegram ID администраторов через запятую (пусто = все имеют доступ)
ADMIN_TG_IDS=123456789,987654321

BACKEND_URL=http://backend:8000

JWT_SECRET=change_this_to_random_secret_64_chars
JWT_EXPIRE_HOURS=168

ADMIN_SECRET=change_this_admin_secret

MIN_WITHDRAWAL=10.0
MAX_WITHDRAWAL_DAY=1000.0
WITHDRAWAL_FEE_PERCENT=5.0

REFERRAL_REWARD=0.50
REFERRAL_MIN_TASKS=3
